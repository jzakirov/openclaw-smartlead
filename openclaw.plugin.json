{
  "id": "smartlead",
  "name": "Smartlead",
  "description": "Receives Smartlead webhook events, normalizes EMAIL_REPLY payloads, and forwards them to an OpenClaw mapped hook (/hooks/smartlead by default).",
  "version": "0.3.1",
  "skills": ["skills/smartlead"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "webhookSecret":        { "type": "string" },
      "openclawHookUrl":      { "type": "string" },
      "openclawHookToken":    { "type": "string" },
      "inboundWebhookPath":   { "type": "string" }
    },
    "required": []
  },
  "uiHints": {
    "webhookSecret":        { "label": "Smartlead Webhook Secret", "sensitive": true, "help": "Optional. Matched against Smartlead payload `secret_key` or secret headers." },
    "openclawHookUrl":      { "label": "OpenClaw Mapped Hook URL", "advanced": true, "help": "Usually auto-derived to /hooks/smartlead from OpenClaw `gateway.port` + `hooks.path`.", "placeholder": "http://127.0.0.1:18789/hooks/smartlead" },
    "openclawHookToken":    { "label": "OpenClaw Hook Token", "sensitive": true, "advanced": true, "help": "Usually auto-derived from OpenClaw `hooks.token`." },
    "inboundWebhookPath":   { "label": "Inbound Webhook Path", "advanced": true, "placeholder": "/smartlead/webhook" }
  }
}
